<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/securevideo/db" VERSION="2026032601" COMMENT="Secure Video Player tables">
  <TABLES>

    <TABLE NAME="local_securevideo_videos" COMMENT="Video metadata">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="filename" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending"/>
        <FIELD NAME="duration" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="filesize" TYPE="int" LENGTH="20" NOTNULL="false" DEFAULT="0"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS><KEY NAME="primary" TYPE="primary" FIELDS="id"/></KEYS>
      <INDEXES><INDEX NAME="idx_status" UNIQUE="false" FIELDS="status"/></INDEXES>
    </TABLE>

    <TABLE NAME="local_securevideo_access" COMMENT="Video access audit log">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="videoid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="accesscode" TYPE="char" LENGTH="12" NOTNULL="true"/>
        <FIELD NAME="ip" TYPE="char" LENGTH="45" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_videoid" TYPE="foreign" FIELDS="videoid" REFTABLE="local_securevideo_videos" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_accesscode" UNIQUE="false" FIELDS="accesscode"/>
        <INDEX NAME="idx_userid" UNIQUE="false" FIELDS="userid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_securevideo_plists" COMMENT="Course playlists">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="sequential" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS><KEY NAME="primary" TYPE="primary" FIELDS="id"/></KEYS>
    </TABLE>

    <TABLE NAME="local_securevideo_plvids" COMMENT="Playlist-video mapping with sort order">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="playlistid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="videoid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_playlistid" TYPE="foreign" FIELDS="playlistid" REFTABLE="local_securevideo_plists" REFFIELDS="id"/>
        <KEY NAME="fk_videoid" TYPE="foreign" FIELDS="videoid" REFTABLE="local_securevideo_videos" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_playlist_sort" UNIQUE="false" FIELDS="playlistid, sortorder"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_securevideo_progress" COMMENT="Per-user per-video watch progress">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="playlistid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="videoid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="watchedseconds" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="totalseconds" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="percent" TYPE="int" LENGTH="3" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="completed" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="lastposition" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS><KEY NAME="primary" TYPE="primary" FIELDS="id"/></KEYS>
      <INDEXES>
        <INDEX NAME="idx_user_playlist_video" UNIQUE="true" FIELDS="userid, playlistid, videoid"/>
      </INDEXES>
    </TABLE>

  </TABLES>
</XMLDB>
